# OmniMentor — Environment Variables (EXAMPLE)
# Copy to .env locally and fill in values (never commit .env)

# Node environment
NODE_ENV=development

# API
API_HOST=localhost
API_PORT=3001

# Database (sqlite path)
DATABASE_URL=./data/omnimentor.db

# Optional: future integrations (placeholder)
VECTOR_DB_URL=http://localhost:6333
GRAPH_DB_URL=http://localhost:7687

# Phase 2+: vector/graph credentials (use env vars, never hardcode)
# VECTOR_API_KEY=your-key-here
# GRAPH_API_KEY=your-key-here

# Logging
LOG_LEVEL=debug
