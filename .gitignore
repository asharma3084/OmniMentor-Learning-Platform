# Environment & Secrets (CRITICAL: never commit .env)
.env
.env.local
.env.*.local

# Database files
*.db
*.sqlite
*.sqlite3

# Node & package managers
node_modules/
dist/
build/
*.tgz
pnpm-lock.yaml

# Logs & reports
*.log
logs/
reports/**
!reports/week1/.gitkeep
services/api/reports/**
data/

# IDE & OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Process manager
.pm2/

# Sensitive data (personal, company-internal)
# Do NOT commit:
# - .env with real tokens/credentials
# - Raw deployment configs, infra details
# - Employee lists, personal identifiers
# - Internal company data

# Personal office artifacts
personal/**
personal/*.docx
personal/~$*.docx
personal/.DS_Store

# Office document exports (never commit)
*.doc
*.docx
*.odt
*.rtf
