# OmniMentor management config
# This file controls ports and service behavior for scripts/manage.sh.

# Service hosts and ports
API_HOST=127.0.0.1
API_PORT=3001
WEB_HOST=127.0.0.1
WEB_PORT=5173
OLLAMA_HOST=127.0.0.1
OLLAMA_PORT=11434

# API runtime config
DATABASE_URL=./data/omnimentor.db

# Ollama defaults
OLLAMA_DEFAULT_MODEL=llama3.2
AUTO_START_OLLAMA=false

# Health checks
HEALTH_RETRIES=20
HEALTH_INTERVAL_SEC=1
