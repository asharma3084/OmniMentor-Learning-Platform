{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": "..",
    "paths": {
      "@omnimentor/*": ["packages/*/src"],
      "@api/*": ["services/api/src/*"],
      "@web/*": ["apps/web/src/*"],
      "@playwright/test": ["workspace/node_modules/@playwright/test"]
    }
  },
  "include": ["../apps/**/*.ts", "../apps/**/*.tsx", "../services/**/*.ts", "../packages/**/*.ts", "../scripts/**/*.ts", "../tests/**/*.ts"],
  "exclude": ["../node_modules", "../dist", "../build", "../reports", "../data"]
}
