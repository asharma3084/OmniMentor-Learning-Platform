{
  "name": "@omnimentor/root",
  "version": "0.1.0",
  "private": true,
  "description": "OmniMentor — scenario-based deliberate-practice learning app",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "pnpm --filter @omnimentor/api --filter @omnimentor/web run build",
    "dev": "concurrently 'pnpm --filter @omnimentor/api dev' 'pnpm --filter @omnimentor/web dev'",
    "smoke": "tsx scripts/smoke.ts",
    "eval": "tsx scripts/eval_run.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^8.50.0",
    "tsx": "^4.4.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {},
    "peerDependencyRules": {
      "ignoreMissing": []
    }
  }
}
