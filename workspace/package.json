{
  "name": "@omnimentor/root",
  "version": "0.1.0",
  "private": true,
  "description": "OmniMentor — scenario-based deliberate-practice learning app",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "lint": "eslint ../apps ../services ../packages ../scripts ../tests --ext .ts,.tsx -c ../config/.eslintrc.json",
    "test": "vitest run --config ../config/vitest.config.ts",
    "test:watch": "vitest --config ../config/vitest.config.ts",
    "dev:e2e": "concurrently \"API_PORT=10092 DATABASE_URL=../services/api/data/omnimentor-e2e.db pnpm --filter @omnimentor/api dev\" \"VITE_API_URL=http://127.0.0.1:10092 pnpm --filter @omnimentor/web exec vite --host 127.0.0.1 --port 10091\"",
    "test:e2e": "../scripts/e2e.sh",
    "test:e2e:headed": "../scripts/e2e.sh --headed",
    "typecheck": "tsc --noEmit -p ../config/tsconfig.json",
    "build": "pnpm --filter @omnimentor/api --filter @omnimentor/web run build",
    "dev": "concurrently 'pnpm --filter @omnimentor/api dev' 'pnpm --filter @omnimentor/web dev'",
    "smoke": "tsx ../scripts/smoke.ts",
    "eval": "tsx ../scripts/eval_run.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^8.50.0",
    "tsx": "^4.4.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "overrides": {},
    "peerDependencyRules": {
      "ignoreMissing": []
    }
  }
}
